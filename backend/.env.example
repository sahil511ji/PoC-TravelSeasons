# Mode is auto-detected by presence of SUPABASE_URL.
# Leave Supabase vars blank for local dev (SQLite + local disk).

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
SUPABASE_BUCKET=travelseasons-poc

# Local fallback paths
LOCAL_DB_PATH=./data/poc.db
LOCAL_STORAGE_DIR=./storage_local

# Face matching — AWS Rekognition (replaces facenet-pytorch)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=
REKOGNITION_COLLECTION_ID=travelseasons-poc
REKOGNITION_FACE_MATCH_THRESHOLD=80
REKOGNITION_QUALITY_FILTER=AUTO
ALLOW_COLLECTION_DRIFT=false

# Server
PUBLIC_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:8000,http://localhost:3000,http://localhost:5173

# AI Recap Video Pipeline (PoC 1)
GEMINI_API_KEY=
SHOTSTACK_API_KEY=
SHOTSTACK_ENV=stage
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
